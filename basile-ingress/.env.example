DATABASE_URL=postgresql+asyncpg://basile:basile123@basile-postgres:5432/basile_db
REDIS_URL=redis://basile-redis:6379
SECRET_KEY=your-secret-key-change-in-production

# Forwarding — timeout for the HTTP call to the worker (seconds)
FORWARD_TIMEOUT=120

# Dispatcher — background retry loop
DISPATCH_INTERVAL_SECONDS=30
DISPATCH_MAX_RETRIES=50
DISPATCH_RETRY_DELAYS=5,10,30,60,120